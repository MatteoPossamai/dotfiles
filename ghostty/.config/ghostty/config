# ghostty — managed in ~/dotfiles (stow).  Docs: https://ghostty.org/docs/config
# Reload live: Ctrl+Shift+,

# --- shell (login shell here is bash; force zsh) ---
command = /usr/bin/zsh

# --- appearance ---
theme = Catppuccin Mocha
font-family = JetBrainsMono Nerd Font
font-size = 12
window-padding-x = 8
window-padding-y = 6
window-padding-balance = true

# hide the GTK title/header bar (keeps resize border; move with Super+drag)
gtk-titlebar = false
# slight transparency — gauge what's behind, not read it (1.0 = solid black)
background-opacity = 0.92

# --- cursor ---
cursor-style = block
cursor-style-blink = false
mouse-hide-while-typing = true

# --- behaviour ---
copy-on-select = true
scrollback-limit = 10000
confirm-close-surface = false
window-save-state = always
